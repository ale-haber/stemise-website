# STEMise Website Environment Variables

# Supabase Configuration (required for admin mode, forms, and authentication)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Auth routes:
# - /login
# - /signup
# - /dashboard (protected; requires a signed-in Supabase session)

# Cloudflare Turnstile (required for contact and kit request forms)
VITE_TURNSTILE_SITE_KEY=
